# Reference: https://github.com/frappe/frappe_docker/blob/main/docs/environment-variables.md

ERPNEXT_VERSION=version-16

DB_PASSWORD={{ velveta_db_root_password }}

#Only if you use docker secrets for the db password
DB_PASSWORD_SECRETS_FILE=

# Only if you use external database
DB_HOST=
DB_PORT=

# Only if you use external Redis
REDIS_CACHE=
REDIS_QUEUE=

# Only with HTTPS override
LETSENCRYPT_EMAIL={{ velveta_frappe.letsencrypt_email }}

FRAPPE_SITE_NAME_HEADER={{ velveta_sites.prod }}
HTTP_PUBLISH_PORT=
HTTPS_PUBLISH_PORT=
UPSTREAM_REAL_IP_ADDRESS=
UPSTREAM_REAL_IP_HEADER=
UPSTREAM_REAL_IP_RECURSIVE=
PROXY_READ_TIMEOUT=
CLIENT_MAX_BODY_SIZE=
SITES_RULE=Host(`{{ velveta_domains.erp_prod }}`)
NGINX_PROXY_HOSTS={{ velveta_domains.erp_prod }}
