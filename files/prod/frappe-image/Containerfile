# syntax=docker/dockerfile:1.7
ARG PYTHON_VERSION=3.14.2
ARG DEBIAN_BASE=bookworm
FROM python:${PYTHON_VERSION}-slim-${DEBIAN_BASE} AS base

COPY resources/core/nginx/nginx-template.conf /templates/nginx/frappe.conf.template
COPY resources/core/nginx/nginx-entrypoint.sh /usr/local/bin/nginx-entrypoint.sh
COPY resources/core/nginx/security_headers.conf /etc/nginx/snippets/security_headers.conf

ARG WKHTMLTOPDF_VERSION=0.12.6.1-3
ARG WKHTMLTOPDF_DISTRO=bookworm
ARG NODE_VERSION=24.13.0
ENV NVM_DIR=/home/frappe/.nvm
ENV PATH=${NVM_DIR}/versions/node/v${NODE_VERSION}/bin/:${PATH}

RUN useradd -ms /bin/bash frappe \
    && apt-get update \
    && apt-get install --no-install-recommends -y \
    curl \
    git \
    vim \
    locales \
    libc-l10n \
    nginx \
    gettext-base \
    file \
    libpango-1.0-0 \
    libharfbuzz0b \
    libpangoft2-1.0-0 \
    libpangocairo-1.0-0 \
    chromium-headless-shell \
    ffmpeg \
    restic \
    gpg \
    mariadb-client \
    less \
    libpq-dev \
    postgresql-client \
    wait-for-it \
    jq \
    media-types \
    && mkdir -p ${NVM_DIR} \
    && curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.5/install.sh | bash \
    && . ${NVM_DIR}/nvm.sh \
    && nvm install ${NODE_VERSION} \
    && nvm use v${NODE_VERSION} \
    && npm install -g yarn \
    && nvm alias default v${NODE_VERSION} \
    && rm -rf ${NVM_DIR}/.cache \
    && echo 'export NVM_DIR="/home/frappe/.nvm"' >>/home/frappe/.bashrc \
    && echo '[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm' >>/home/frappe/.bashrc \
    && echo '[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion' >>/home/frappe/.bashrc \
    && if [ "$(uname -m)" = "aarch64" ]; then export ARCH=arm64; fi \
    && if [ "$(uname -m)" = "x86_64" ]; then export ARCH=amd64; fi \
    && downloaded_file=wkhtmltox_${WKHTMLTOPDF_VERSION}.${WKHTMLTOPDF_DISTRO}_${ARCH}.deb \
    && curl -sLO https://github.com/wkhtmltopdf/packaging/releases/download/$WKHTMLTOPDF_VERSION/$downloaded_file \
    && apt-get install -y ./$downloaded_file \
    && rm $downloaded_file \
    && localedef -i tr_TR -f UTF-8 tr_TR.UTF-8 \
    && localedef -i en_US -f UTF-8 en_US.UTF-8 \
    && rm -rf /var/lib/apt/lists/* \
    && rm -fr /etc/nginx/sites-enabled/default \
    && mkdir -p /etc/nginx/snippets \
    && pip3 install frappe-bench \
    && sed -i '/user www-data/d' /etc/nginx/nginx.conf \
    && ln -sf /dev/stdout /var/log/nginx/access.log \
    && ln -sf /dev/stderr /var/log/nginx/error.log \
    && touch /run/nginx.pid \
    && chown -R frappe:frappe /etc/nginx/conf.d \
    && chown -R frappe:frappe /etc/nginx/nginx.conf \
    && chown -R frappe:frappe /etc/nginx/snippets \
    && chown -R frappe:frappe /var/log/nginx \
    && chown -R frappe:frappe /var/lib/nginx \
    && chown -R frappe:frappe /run/nginx.pid \
    && chmod 755 /usr/local/bin/nginx-entrypoint.sh \
    && chmod 644 /templates/nginx/frappe.conf.template

FROM base AS builder

RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install --no-install-recommends -y \
    wget \
    libcairo2-dev \
    libpango1.0-dev \
    libjpeg-dev \
    libgif-dev \
    librsvg2-dev \
    libpq-dev \
    libffi-dev \
    liblcms2-dev \
    libldap2-dev \
    libmariadb-dev \
    libsasl2-dev \
    libtiff5-dev \
    libwebp-dev \
    pkg-config \
    redis-tools \
    rlwrap \
    tk8.6-dev \
    cron \
    gcc \
    build-essential \
    libbz2-dev \
    && rm -rf /var/lib/apt/lists/*

ARG APPS_JSON_BASE64
RUN if [ -n "${APPS_JSON_BASE64}" ]; then \
    mkdir /opt/frappe && echo "${APPS_JSON_BASE64}" | base64 -d > /opt/frappe/apps.json; \
  fi

USER frappe

ARG FRAPPE_BRANCH=version-16
ARG FRAPPE_PATH=https://github.com/frappe/frappe
ARG FRAPPE_COMMIT=
ARG APP_SOURCES_FINGERPRINT=missing
RUN --mount=type=secret,id=github_pat,uid=1000,gid=1000,mode=0400 \
  export APP_INSTALL_ARGS="" && \
  export GIT_TOKEN_CONFIGURED="" && \
  export APP_SOURCES_FINGERPRINT="${APP_SOURCES_FINGERPRINT}" && \
  if [ -f /run/secrets/github_pat ]; then \
    export GITHUB_PAT="$(tr -d '\n' </run/secrets/github_pat)"; \
    if [ -n "${GITHUB_PAT}" ]; then \
      git config --global url."https://oauth2:${GITHUB_PAT}@github.com/".insteadOf "https://github.com/" && \
      export GIT_TOKEN_CONFIGURED=1; \
    fi; \
  fi && \
  if [ -n "${APPS_JSON_BASE64}" ]; then \
    export APP_INSTALL_ARGS="--apps_path=/opt/frappe/apps.json"; \
  fi && \
  printf '%s\n' "${APP_SOURCES_FINGERPRINT}" > /tmp/app-sources-fingerprint && \
  bench init ${APP_INSTALL_ARGS} \
    --frappe-branch=${FRAPPE_BRANCH} \
    --frappe-path=${FRAPPE_PATH} \
    --no-procfile \
    --no-backups \
    --skip-redis-config-generation \
    --verbose \
    /home/frappe/frappe-bench && \
  cd /home/frappe/frappe-bench && \
  echo "{}" > sites/common_site_config.json && \
  if [ -z "${FRAPPE_COMMIT}" ]; then \
    echo "FRAPPE_COMMIT is required for production image builds." >&2; \
    exit 1; \
  fi && \
  frappe_remote="$(git -C apps/frappe remote | head -n1)" && \
  git -C apps/frappe fetch --depth=1 "${frappe_remote}" "${FRAPPE_COMMIT}" && \
  git -C apps/frappe reset --hard && \
  git -C apps/frappe clean -fd && \
  git -C apps/frappe checkout -f "${FRAPPE_COMMIT}" && \
  python -c "exec('''import json\nimport subprocess\nimport sys\nfrom pathlib import Path\n\napps_json = Path(\"/opt/frappe/apps.json\")\nif apps_json.exists():\n    apps = json.loads(apps_json.read_text())\n    for app in apps:\n        commit = (app.get(\"commit\") or \"\").strip()\n        if not commit:\n            continue\n        app_name = Path(app[\"url\"].rstrip(\"/\").removesuffix(\".git\")).name\n        app_path = f\"apps/{app_name}\"\n        remotes = subprocess.check_output([\"git\", \"-C\", app_path, \"remote\"], text=True).splitlines()\n        remote = remotes[0] if remotes else \"origin\"\n        fetch = subprocess.run([\"git\", \"-C\", app_path, \"fetch\", \"--depth=1\", remote, commit], text=True, capture_output=True)\n        if fetch.returncode != 0:\n            sys.stderr.write(f\"WARN: could not fetch pinned commit for {app_name}: {commit}; keeping checked out branch commit.\\\\n\")\n            sys.stderr.write(fetch.stderr)\n            continue\n        subprocess.run([\"git\", \"-C\", app_path, \"reset\", \"--hard\"], check=True)\n        subprocess.run([\"git\", \"-C\", app_path, \"clean\", \"-fd\"], check=True)\n        subprocess.run([\"git\", \"-C\", app_path, \"checkout\", \"-f\", commit], check=True)\n''')" && \
  python -c "exec('''import json\nimport subprocess\nimport sys\nfrom pathlib import Path\n\napps_json = Path(\"/opt/frappe/apps.json\")\nif apps_json.exists():\n    apps = json.loads(apps_json.read_text())\n    for app in apps:\n        commit = (app.get(\"commit\") or \"\").strip()\n        app_name = Path(app[\"url\"].rstrip(\"/\").removesuffix(\".git\")).name\n        if not commit:\n            sys.stderr.write(f\"ERROR: missing pinned commit for {app_name}.\\\\n\")\n            sys.exit(1)\n        app_path = f\"apps/{app_name}\"\n        head = subprocess.check_output([\"git\", \"-C\", app_path, \"rev-parse\", \"HEAD\"], text=True).strip()\n        if head != commit:\n            sys.stderr.write(f\"ERROR: {app_name} checked out {head}, expected {commit}.\\\\n\")\n            sys.exit(1)\n''')" && \
  python -c "from pathlib import Path; path = Path('/home/frappe/frappe-bench/apps/erpnext/erpnext/public/js/setup_wizard.js'); \
text = path.read_text() if path.exists() else ''; \
old = '\\t\\tbefore_show: function () {\\n\\t\\t\\tthis.load_chart_of_accounts(this);\\n\\t\\t\\tthis.set_fy_dates(this);\\n\\t\\t},\\n'; \
new = '\\t\\tbefore_show: function () {\\n\\t\\t\\tlet country = frappe.wizard.values.country || frappe.defaults.get_default(\\\"country\\\");\\n\\n\\t\\t\\tif (!country) {\\n\\t\\t\\t\\tfrappe.set_route(\\\"setup-wizard/0\\\");\\n\\t\\t\\t\\treturn false;\\n\\t\\t\\t}\\n\\n\\t\\t\\tthis.load_chart_of_accounts(this);\\n\\t\\t\\tthis.set_fy_dates(this);\\n\\t\\t},\\n'; \
path.write_text(text.replace(old, new, 1)) if path.exists() and old in text else None" && \
  if [ "${GIT_TOKEN_CONFIGURED}" = "1" ]; then \
    git config --global --unset-all url."https://oauth2:${GITHUB_PAT}@github.com/".insteadOf; \
  fi && \
  find apps -mindepth 1 -path "*/.git" | xargs rm -fr

FROM base AS backend

USER frappe

ARG APP_SOURCES_FINGERPRINT=missing
LABEL org.velveta.app-sources-fingerprint="${APP_SOURCES_FINGERPRINT}"

COPY --from=builder --chown=frappe:frappe /home/frappe/frappe-bench /home/frappe/frappe-bench

WORKDIR /home/frappe/frappe-bench

VOLUME [ \
  "/home/frappe/frappe-bench/sites", \
  "/home/frappe/frappe-bench/sites/assets", \
  "/home/frappe/frappe-bench/logs" \
]

CMD [ \
  "/home/frappe/frappe-bench/env/bin/gunicorn", \
  "--chdir=/home/frappe/frappe-bench/sites", \
  "--bind=0.0.0.0:8000", \
  "--threads=4", \
  "--workers=2", \
  "--worker-class=gthread", \
  "--worker-tmp-dir=/dev/shm", \
  "--timeout=120", \
  "--preload", \
  "frappe.app:application" \
]
